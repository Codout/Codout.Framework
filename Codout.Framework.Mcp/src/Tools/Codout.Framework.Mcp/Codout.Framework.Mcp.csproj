<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Codout.Framework.Mcp</RootNamespace>
    <AssemblyName>Codout.Framework.Mcp</AssemblyName>
    <LangVersion>latest</LangVersion>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>codout-mcp</ToolCommandName>
    <PackageId>Codout.Framework.Mcp</PackageId>
    <Title>Codout Framework MCP Server</Title>
    <Description>Servidor MCP (Model Context Protocol) que expõe a constituição, catálogo, padrões de tela, recipes e referências ouro do ecossistema Codout para clientes como Claude Code, Claude Desktop, VSCode e Cursor.</Description>
    <PackageTags>mcp;codout;ai;claude;model-context-protocol;dotnet-tool</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release' AND Exists('D:\Packages\Codout Framework')">
    <PackageOutputPath>D:\Packages\Codout Framework</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.3" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.3" />
    <PackageReference Include="ModelContextProtocol" Version="1.1.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\..\..\docs\ai\**\*.md">
      <LogicalName>knowledge/%(RecursiveDir)%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\..\docs\ai\**\*.json">
      <LogicalName>knowledge/%(RecursiveDir)%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
